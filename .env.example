# ========== Docker Umgebungsvariablen ==========
# Diese Datei kopieren nach .env und Werte anpassen
# cp .env.example .env

# MySQL Datenbank
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PW
MYSQL_USER=erp_user
MYSQL_PASSWORD=CHANGE_ME_DB_PW

# Admin-Zugangsdaten
APP_ADMIN_USER=Marvin
APP_ADMIN_PASS=123456

# Optional: SMTP E-Mail (für E-Mail-Funktionen)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASS=

# Optional: Gemini API Key (für KI-Funktionen)
# AI_GEMINI_API_KEY=

# Optional: Zeiterfassung URL
# ZEITERFASSUNG_URL=http://localhost:8080
