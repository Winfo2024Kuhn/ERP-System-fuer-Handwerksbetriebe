# ========== Docker Umgebungsvariablen ==========
# Diese Datei kopieren nach .env und Werte anpassen
# cp .env.example .env

# MariaDB Datenbank
# MARIADB_ROOT_PASSWORD=erp_root_2024
# MARIADB_DATABASE=kalkulationsprogramm_db
# MARIADB_USER=erp_user
# MARIADB_PASSWORD=erp_secret_2024

# App-Datenbank-Verbindung (optional überschreiben)
# Standard: App verbindet sich mit MariaDB aus Docker Compose.
#
# Für externes MySQL (Beispiel):
# APP_DB_URL=jdbc:mysql://host.docker.internal:3306/kalkulationsprogramm_db?useUnicode=true&characterEncoding=UTF-8&allowPublicKeyRetrieval=true&useSSL=false&serverTimezone=UTC
# APP_DB_USER=mysql_user
# APP_DB_PASS=mysql_password
#
# Für externes MariaDB (Beispiel):
# APP_DB_URL=jdbc:mariadb://host.docker.internal:3306/kalkulationsprogramm_db?useUnicode=true&characterEncoding=UTF-8
# APP_DB_USER=mariadb_user
# APP_DB_PASS=mariadb_password

# Admin-Zugangsdaten
APP_ADMIN_USER=dein_admin_benutzername
APP_ADMIN_PASS=change_me_strong_password

# Optional: SMTP E-Mail (für E-Mail-Funktionen)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASS=

# Optional: Gemini API Key (für KI-Funktionen)
# AI_GEMINI_API_KEY=

# Optional: Zeiterfassung URL
# ZEITERFASSUNG_URL=http://localhost:8080
