        <mxCell id="storno-box" value="&lt;b&gt;❌ Storno-Prozess (GoBD)&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size:10px&quot;&gt;1. Neues STORNO-Dokument wird erstellt&lt;br&gt;2. Original erhält storniert=true + storniertAm&lt;br&gt;3. Beide Dokumente bleiben erhalten&lt;br&gt;4. Audit-Trail vollständig&lt;br&gt;5. Löschung NICHT möglich (außer Entwürfe)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef2f2;strokeColor=#dc2626;fontSize=12;shadow=1;align=left;spacingLeft=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="740" y="1040" width="340" height="120" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
