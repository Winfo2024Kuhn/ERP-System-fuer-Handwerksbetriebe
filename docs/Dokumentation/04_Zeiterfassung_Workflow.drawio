        <!-- ==================== AUDIT TRAIL ==================== -->
        <mxCell id="audit-section" value="4. AUDIT-TRAIL (GoBD-konform)" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];fontSize=16;fontStyle=1;fontColor=#dc2626;" vertex="1" parent="1">
          <mxGeometry x="60" y="830" width="400" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="audit-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef2f2;strokeColor=#dc2626;fontSize=12;arcSize=8;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="60" y="870" width="1200" height="220" as="geometry"/>
        </mxCell>

        <mxCell id="zeit-audit" value="&lt;b&gt;ZeitbuchungAudit&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Vollständiger Snapshot der Zeitbuchung&lt;br&gt;&lt;br&gt;• versionNummer (1 = Ersterfassung, 2+ = Änderung)&lt;br&gt;• auditAktion: ERSTELLT | GEAENDERT | STORNIERT&lt;br&gt;• aenderungsgrund (Pflichtfeld!)&lt;br&gt;• geaendertVon (wer)&lt;br&gt;• geaendertAm (wann)&lt;br&gt;• geaendertVia: MOBILE_APP | DESKTOP&lt;br&gt;&lt;br&gt;→ Lückenlose Versionshistorie (Vollrekonstruktion)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff1f2;strokeColor=#dc2626;fontSize=12;shadow=1;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="890" width="330" height="185" as="geometry"/>
        </mxCell>

        <mxCell id="korr-audit" value="&lt;b&gt;ZeitkontoKorrekturAudit&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Eigener Audit-Trail für Korrekturen&lt;br&gt;&lt;br&gt;• Korrektur-Snapshot&lt;br&gt;• Begründung Pflicht&lt;br&gt;• Vollständige Nachvollziehbarkeit&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff1f2;strokeColor=#dc2626;fontSize=12;shadow=1;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="440" y="890" width="280" height="130" as="geometry"/>
        </mxCell>

        <mxCell id="audit-rules" value="&lt;b&gt;⚖️ GoBD Audit-Regeln&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size:10px&quot;&gt;✅ Jede Änderung = neuer Snapshot&lt;br&gt;✅ Pflichtfeld: Änderungsgrund&lt;br&gt;✅ Wer, Wann, Via wird erfasst&lt;br&gt;✅ Versionsnummer zählt hoch&lt;br&gt;✅ Keine Snapshots werden gelöscht&lt;br&gt;✅ idempotencyKey gegen Doppelerfassung&lt;br&gt;✅ Vollständige Rekonstruktion möglich&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef9c3;strokeColor=#a16207;fontSize=12;shadow=1;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="750" y="890" width="280" height="160" as="geometry"/>
        </mxCell>

        <!-- ==================== CACHING ==================== -->
        <mxCell id="cache-title" value="5. PERFORMANCE-CACHING" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];fontSize=16;fontStyle=1;fontColor=#a16207;" vertex="1" parent="1">
          <mxGeometry x="800" y="80" width="400" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="cache-box" value="&lt;b&gt;MonatsSaldo-Caching-Strategie&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size:10px&quot;&gt;&lt;b&gt;Aktueller/Zukünftiger Monat:&lt;/b&gt;&lt;br&gt;→ Immer live berechnen&lt;br&gt;&lt;br&gt;&lt;b&gt;Vergangener Monat + Cache gültig:&lt;/b&gt;&lt;br&gt;→ Cache verwenden (schnell!)&lt;br&gt;&lt;br&gt;&lt;b&gt;Vergangener Monat + Cache ungültig:&lt;/b&gt;&lt;br&gt;→ Neuberechnung + speichern&lt;br&gt;&lt;br&gt;&lt;b&gt;Invalidierung:&lt;/b&gt;&lt;br&gt;gueltig=false bei Quelldaten-Änderung&lt;br&gt;&lt;br&gt;&lt;b&gt;Warmup (MonatsSaldoWarmupService):&lt;/b&gt;&lt;br&gt;Vorberechnung beim Start&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef9c3;strokeColor=#a16207;fontSize=12;shadow=1;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="800" y="120" width="310" height="250" as="geometry"/>
        </mxCell>

