        <mxCell id="zeitbuchung" value="&lt;b&gt;Zeitbuchung&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size:10px&quot;&gt;mitarbeiter_id (FK)&lt;br&gt;projekt_id (FK)&lt;br&gt;arbeitsgang_id (FK)&lt;br&gt;produktkategorie_id (FK)&lt;br&gt;startZeit, endZeit&lt;br&gt;pauseMinuten, istStunden&lt;br&gt;idempotencyKey (UUID)&lt;br&gt;erfassungsQuelle&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontSize=12;shadow=1;align=left;spacingLeft=10;" vertex="1" parent="1">
