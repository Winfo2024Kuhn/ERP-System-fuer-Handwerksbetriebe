        <mxCell id="zeitkonto" value="&lt;b&gt;Zeitkonto&lt;/b&gt;&lt;hr&gt;&lt;font style=&quot;font-size:10px&quot;&gt;mitarbeiter_id (FK)&lt;br&gt;monat, jahr&lt;br&gt;sollStunden&lt;br&gt;wochenstunden&lt;br&gt;urlaubstage&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontSize=12;shadow=1;align=left;spacingLeft=10;" vertex="1" parent="1">
